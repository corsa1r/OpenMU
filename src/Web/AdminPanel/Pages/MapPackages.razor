@page "/maps/packages"
@using MUnique.OpenMU.CustomMaps
@using MUnique.OpenMU.Web.AdminPanel.Services
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>OpenMU: Map Packages</PageTitle>
<Breadcrumb IsFirstFromRoot="true" Caption="Map Packages" />

<h2>Map Packages</h2>
<p class="text-muted">
    Import a <code>.bmap</code> map package produced by the in-game editor.
    First import seeds map identity, spawn gate and warp-list entry; subsequent
    imports only refresh the binary asset files (level requirement, costs and
    spawn coords stay as set in the admin panel).
</p>

<div class="card mb-3">
    <div class="card-header">Import package</div>
    <div class="card-body">
        <Microsoft.AspNetCore.Components.Forms.InputFile OnChange="this.OnFileChosen" accept=".bmap,.zip" class="form-control mb-2" />
        @if (!string.IsNullOrEmpty(this._chosenFileName))
        {
            <p class="mb-2">Selected: <strong>@this._chosenFileName</strong> (@this._chosenFileSize bytes)</p>
        }
        <button class="btn btn-primary" disabled="@(this._chosenFile is null || this._isImporting)"
                @onclick="this.OnImportClickAsync">
            @if (this._isImporting)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            Import
        </button>
    </div>
</div>

@if (this._lastResult is not null)
{
    var resultClass = this._lastResult.Success ? "alert-success" : "alert-danger";
    <div class="alert @resultClass">
        @if (this._lastResult.Success)
        {
            <p>
                @(this._lastResult.IsCreate ? "Created" : "Updated")
                map <strong>@this._lastResult.MapName</strong> (Number @this._lastResult.MapNumber).
                Wrote @this._lastResult.AssetsWritten.Count asset(s).
                @if (this._lastResult.PlayersWarpedToSafezone > 0)
                {
                    <span>Warped @this._lastResult.PlayersWarpedToSafezone player(s) to safezone so the new terrain takes effect.</span>
                }
            </p>
            @if (this._lastResult.AssetsWritten.Count > 0)
            {
                <ul class="mb-0">
                    @foreach (var asset in this._lastResult.AssetsWritten)
                    {
                        <li><code>@asset</code></li>
                    }
                </ul>
            }
        }
        else
        {
            <p>Import failed: @this._lastResult.Error</p>
        }
    </div>
}

<div class="card">
    <div class="card-header">Installed custom maps (filesystem)</div>
    <div class="card-body">
        @if (this._installedMaps is { Count: > 0 })
        {
            <table class="table table-sm">
                <thead><tr><th>Number</th><th>Folder</th><th></th></tr></thead>
                <tbody>
                @foreach (var n in this._installedMaps)
                {
                    <tr>
                        <td>@n</td>
                        <td><code>@this.AssetStore.GetMapDirectory(n)</code></td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary" href="api/maps/packages/@n" download>
                                Export
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">No custom maps installed yet — import a package above.</p>
        }
    </div>
</div>
